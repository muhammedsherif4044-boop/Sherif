<!-- ═══════════════════════════════ ADD VACANCY MODAL ═══════════════════════════════ -->
<div class="modal-overlay" id="add-modal">
  <div class="modal">
    <h3><i class="ti ti-plus" style="color:var(--green)"></i> Add new vacancy</h3>
    <div class="form-group">
      <label>Job role title</label>
      <input type="text" id="new-role" placeholder="e.g. Cashier, Kitchen Helper" />
    </div>
    <div class="form-group">
      <label>Number of slots</label>
      <input type="text" id="new-slots" placeholder="e.g. 2" />
    </div>
    <div class="form-group">
      <label>Working hours</label>
      <input type="text" id="new-hours" placeholder="e.g. Weekends, 9am–3pm" />
    </div>
    <div class="form-group">
      <label>Pay rate (per hour)</label>
      <input type="text" id="new-pay" placeholder="e.g. ₹200/hr" />
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" style="flex:1" onclick="closeModal()">Cancel</button>
      <button class="btn btn-green" style="flex:1" onclick="saveVacancy()">
        <i class="ti ti-check"></i> Save listing
      </button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════ EDIT VACANCY MODAL ═══════════════════════════════ -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal">
    <h3><i class="ti ti-edit" style="color:var(--purple)"></i> Edit vacancy</h3>
    <input type="hidden" id="edit-index" />
    <div class="form-group">
      <label>Job role title</label>
      <input type="text" id="edit-role" />
    </div>
    <div class="form-group">
      <label>Number of slots</label>
      <input type="text" id="edit-slots-input" />
    </div>
    <div class="form-group">
      <label>Working hours</label>
      <input type="text" id="edit-hours" />
    </div>
    <div class="form-group">
      <label>Pay rate (per hour)</label>
      <input type="text" id="edit-pay" />
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" style="flex:1" onclick="closeModal()">Cancel</button>
      <button class="btn btn-purple" style="flex:1" onclick="updateVacancy()">
        <i class="ti ti-check"></i> Save changes
      </button>
    </div>
  </div>
</div>


<script>
  // ── DATA ──
  const shops = [
    {
      id: 0,
      name: "Lulu Hypermarket",
      img: "https://upload.wikimedia.org/wikipedia/commons/thumb/4/43/LuLu_Mall%2C_Kochi.jpg/1280px-LuLu_Mall%2C_Kochi.jpg",
      emoji: "🏬", bg: "#E6F1FB",
      category: "Retail",
      address: "34/1000, Old NH 47, Edappally Junction, Nethaji Nagar, Edappally, Kochi, Ernakulam, Kerala 682024",
      hours: "Mon–Sun, 9am–10pm", pay: "₹180–220/hr",
      vacancies: [
        { role: "Sales", slots: 12 },
        { role: "Cashiering", slots: 3 },
        { role: "Operations", slots: 2 },
      ]
    },
    {
      id: 1,
      name: "Green Leaf Bakery",
      img: "",
      emoji: "🥐", bg: "#FAEEDA",
      category: "Food & Beverage",
      address: "12, MG Road, Ravipuram, Kochi, Kerala 682016",
      hours: "Weekends, 8am–2pm", pay: "₹175–190/hr",
      vacancies: [
        { role: "Counter Assistant", slots: 2 },
        { role: "Kitchen Helper", slots: 1 },
      ]
    },
    {
      id: 2,
      name: "TechZone Store",
      img: "",
      emoji: "💻", bg: "#EEEDFE",
      category: "Tech",
      address: "G-14, Oberon Mall, Edapally, Kochi, Kerala 682024",
      hours: "Mon–Sat, 10am–6pm", pay: "₹200–250/hr",
      vacancies: [
        { role: "Sales Associate", slots: 1 },
        { role: "Tech Support", slots: 2 },
      ]
    },
    {
      id: 3,
      name: "Speedy Delivery Co.",
      img: "",
      emoji: "🛵", bg: "#FAECE7",
      category: "Delivery",
      address: "Near Vytilla Hub, Vytilla, Kochi, Kerala 682019",
      hours: "Flexible shifts", pay: "₹230–260/hr",
      vacancies: [
        { role: "Delivery Partner", slots: 4 },
        { role: "Sorting Staff", slots: 2 },
      ]
    },
    {
      id: 4,
      name: "Café Mocha",
      img: "",
      emoji: "☕", bg: "#E1F5EE",
      category: "Food & Beverage",
      address: "2nd Floor, Centre Square Mall, MG Road, Kochi, Kerala 682035",
      hours: "Weekday mornings", pay: "₹170–195/hr",
      vacancies: [
        { role: "Barista", slots: 1 },
        { role: "Cashier", slots: 1 },
      ]
    },
    {
      id: 5,
      name: "Sunrise Supermart",
      img: "",
      emoji: "🛒", bg: "#E6F1FB",
      category: "Retail",
      address: "Near KSRTC Bus Stand, Aluva, Ernakulam, Kerala 683101",
      hours: "Evenings, 5–9pm", pay: "₹155–175/hr",
      vacancies: [
        { role: "Stock Helper", slots: 2 },
        { role: "Checkout Staff", slots: 2 },
        { role: "Security", slots: 1 },
      ]
    },
  ];

  let applied = new Set();

  const vacancies = [
    { role: "Counter Assistant", slots: 2, hours: "Weekends, 8am–2pm", pay: "₹180/hr", status: true },
    { role: "Kitchen Helper", slots: 1, hours: "Weekday evenings", pay: "₹160/hr", status: false },
    { role: "Cashier", slots: 1, hours: "Mon–Fri, 3–8pm", pay: "₹175/hr", status: true },
  ];

  // ── ROUTING ──
  function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    window.scrollTo(0, 0);
    if (id === 'page-user-dashboard') renderJobs();
    if (id === 'page-owner-dashboard') { renderStats(); renderVacancies(); }
  }

  // ── JOB SEEKER ──
  function filterJobs() { renderJobs(); }

  function renderJobs() {
    const q = (document.getElementById('job-search')?.value || '').toLowerCase();
    const cat = document.getElementById('job-category')?.value || '';
    const filtered = shops.filter(s =>
      (!q || s.name.toLowerCase().includes(q) || s.category.toLowerCase().includes(q) ||
             s.vacancies.some(v => v.role.toLowerCase().includes(q))) &&
      (!cat || s.category === cat)
    );
    const totalSlots = filtered.reduce((a, s) => a + s.vacancies.reduce((b, v) => b + v.slots, 0), 0);
    document.getElementById('job-count-badge').textContent = totalSlots + ' openings';
    const el = document.getElementById('job-list');
    if (filtered.length === 0) {
      el.innerHTML = '<div class="empty"><i class="ti ti-search-off"></i><p>No shops found matching your search.</p></div>';
      return;
    }
    el.innerHTML = '<div class="shop-cards-wrap">' + filtered.map(s => {
      const imgTag = s.img
        ? `<img src="${s.img}" alt="${s.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
        : '';
      const fallback = `<div style="display:${s.img?'none':'flex'};width:100%;height:100%;align-items:center;justify-content:center;font-size:48px;background:${s.bg}">${s.emoji}</div>`;

      const vacancyRows = s.vacancies.map((v, vi) => {
        const key = `${s.id}-${vi}`;
        const isApplied = applied.has(key);
        return `<div class="vacancy-row">
          <div class="vacancy-left">
            <span class="vacancy-role-name">${v.role}:</span>
            <span class="vacancy-count">${v.slots}</span>
          </div>
          ${isApplied
            ? `<button class="btn-apply applied"><i class="ti ti-check"></i> Applied</button>`
            : `<button class="btn-apply" onclick="applyVacancy('${key}')">Apply</button>`}
        </div>`;
      }).join('');

      return `<div class="shop-card fade-up">
        <div class="shop-img-wrap">${imgTag}${fallback}</div>
        <div class="shop-body">
          <div class="shop-name">${s.name}</div>
          <div class="shop-address"><strong>Address:</strong> ${s.address}</div>
          <div class="vacancies-label">Job vacancies</div>
          ${vacancyRows}
        </div>
      </div>`;
    }).join('') + '</div>';
  }

  function applyVacancy(key) {
    applied.add(key);
    renderJobs();
  }

  // ── SHOP OWNER ──
  function renderStats() {
    const open = vacancies.filter(v => v.status).length;
    document.getElementById('owner-stats').innerHTML = `
      <div class="stat-box s-purple"><div class="big">${open}</div><div class="lbl">Open vacancies</div></div>
      <div class="stat-box s-green"><div class="big">12</div><div class="lbl">Applications</div></div>
      <div class="stat-box s-amber"><div class="big">5</div><div class="lbl">Shortlisted</div></div>
    `;
  }

  function renderVacancies() {
    const el = document.getElementById('vacancy-list');
    if (vacancies.length === 0) {
      el.innerHTML = '<div class="empty"><i class="ti ti-clipboard-off"></i><p>No vacancies yet. Add your first listing!</p></div>';
      return;
    }
    el.innerHTML = vacancies.map((v, i) => `
      <div class="vacancy-card fade-up">
        <div class="vc-top">
          <div>
            <div class="vc-title">${v.role}</div>
            <div class="vc-slots"><i class="ti ti-users" style="font-size:12px;vertical-align:-1px"></i> ${v.slots} slot${v.slots>1?'s':''} &nbsp;·&nbsp; ${v.hours} &nbsp;·&nbsp; ${v.pay}</div>
          </div>
          <button class="toggle-btn ${v.status ? 'toggle-on' : 'toggle-off'}" onclick="toggleVacancy(${i})">
            <i class="ti ${v.status ? 'ti-eye' : 'ti-eye-off'}"></i>
            ${v.status ? 'Visible' : 'Hidden'}
          </button>
        </div>
        <div class="vc-footer">
          <button class="btn-edit" onclick="openEditModal(${i})"><i class="ti ti-edit"></i> Edit listing</button>
          <button class="btn-del" onclick="removeVacancy(${i})"><i class="ti ti-trash"></i></button>
        </div>
      </div>`).join('');
    renderStats();
  }

  function toggleVacancy(i) {
    vacancies[i].status = !vacancies[i].status;
    renderVacancies();
  }

  function removeVacancy(i) {
    if (confirm('Remove this vacancy?')) {
      vacancies.splice(i, 1);
      renderVacancies();
    }
  }

  // ── MODALS ──
  function openAddModal() {
    document.getElementById('new-role').value = '';
    document.getElementById('new-slots').value = '';
    document.getElementById('new-hours').value = '';
    document.getElementById('new-pay').value = '';
    document.getElementById('add-modal').classList.add('open');
  }

  function openEditModal(i) {
    const v = vacancies[i];
    document.getElementById('edit-index').value = i;
    document.getElementById('edit-role').value = v.role;
    document.getElementById('edit-slots-input').value = v.slots;
    document.getElementById('edit-hours').value = v.hours;
    document.getElementById('edit-pay').value = v.pay;
    document.getElementById('edit-modal').classList.add('open');
  }

  function closeModal() {
    document.querySelectorAll('.modal-overlay').forEach(m => m.classList.remove('open'));
  }

  function saveVacancy() {
    const role = document.getElementById('new-role').value.trim();
    const slots = parseInt(document.getElementById('new-slots').value) || 1;
    const hours = document.getElementById('new-hours').value.trim() || 'Flexible';
    const pay = document.getElementById('new-pay').value.trim() || '₹200/hr';
    if (!role) { alert('Please enter a job role.'); return; }
    vacancies.push({ role, slots, hours, pay, status: true });
    closeModal();
    renderVacancies();
  }

  function updateVacancy() {
    const i = parseInt(document.getElementById('edit-index').value);
    vacancies[i].role = document.getElementById('edit-role').value.trim() || vacancies[i].role;
    vacancies[i].slots = parseInt(document.getElementById('edit-slots-input').value) || vacancies[i].slots;
    vacancies[i].hours = document.getElementById('edit-hours').value.trim() || vacancies[i].hours;
    vacancies[i].pay = document.getElementById('edit-pay').value.trim() || vacancies[i].pay;
    closeModal();
    renderVacancies();
  }

  // Close modal on overlay click
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
  });

  // ── DISTRICT PICKER ──
  const keralaDistricts = [
    "Thiruvananthapuram", "Kollam", "Pathanamthitta", "Alappuzha",
    "Kottayam", "Idukki", "Ernakulam (Kochi)", "Thrissur",
    "Palakkad", "Malappuram", "Kozhikode", "Wayanad",
    "Kannur", "Kasaragod"
  ];

  let selectedDistrict = "Ernakulam (Kochi)";

  function buildDistrictMenu() {
    const list = document.getElementById('district-list');
    if (!list) return;
    list.innerHTML = keralaDistricts.map(d => `
      <div class="district-item ${d === selectedDistrict ? 'active' : ''}" onclick="selectDistrict('${d}')">
        <i class="ti ti-map-pin"></i> ${d}
      </div>`).join('');
  }

  function toggleDistrictMenu() {
    const menu = document.getElementById('district-menu');
    const isOpen = menu.classList.contains('open');
    menu.classList.toggle('open', !isOpen);
    if (!isOpen) buildDistrictMenu();
  }

  function selectDistrict(name) {
    selectedDistrict = name;
    const shortName = name.replace(' (Kochi)', '');
    document.getElementById('district-label').textContent = shortName + ', Kerala';
    document.getElementById('district-menu').classList.remove('open');
  }

  // Close district menu when clicking outside
  document.addEventListener('click', e => {
    const wrap = document.querySelector('.district-picker-wrap');
    if (wrap && !wrap.contains(e.target)) {
      document.getElementById('district-menu')?.classList.remove('open');
    }
  });
</script>
</body>
</html>
